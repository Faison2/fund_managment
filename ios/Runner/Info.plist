<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <key>CADisableMinimumFrameDurationOnPhone</key>
        <true/>

        <key>CFBundleDevelopmentRegion</key>
        <string>$(DEVELOPMENT_LANGUAGE)</string>

        <key>CFBundleDisplayName</key>
        <string>Invest Mkononi</string>

        <key>CFBundleExecutable</key>
        <string>$(EXECUTABLE_NAME)</string>

        <key>CFBundleIdentifier</key>
        <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

        <key>CFBundleInfoDictionaryVersion</key>
        <string>6.0</string>

        <key>CFBundleName</key>
        <string>tsl</string>

        <key>CFBundlePackageType</key>
        <string>APPL</string>

        <key>CFBundleShortVersionString</key>
        <string>$(FLUTTER_BUILD_NAME)</string>

        <key>CFBundleSignature</key>
        <string>????</string>

        <key>CFBundleVersion</key>
        <string>$(FLUTTER_BUILD_NUMBER)</string>

        <!-- URL schemes this app can open -->
        <key>LSApplicationQueriesSchemes</key>
        <array>
            <string>geo</string>
            <string>comgooglemaps</string>
            <string>tel</string>
            <string>mailto</string>
            <string>whatsapp</string>
            <string>https</string>
            <string>http</string>
        </array>

        <key>LSRequiresIPhoneOS</key>
        <true/>

        <key>UIApplicationSupportsIndirectInputEvents</key>
        <true/>

        <key>UILaunchStoryboardName</key>
        <string>LaunchScreen</string>

        <key>UIMainStoryboardFile</key>
        <string>Main</string>

        <!-- Allow all HTTP/HTTPS traffic (needed for self-signed or non-standard endpoints) -->
        <key>NSAppTransportSecurity</key>
        <dict>
            <key>NSAllowsArbitraryLoads</key>
            <true/>
        </dict>

        <key>UISupportedInterfaceOrientations</key>
        <array>
            <string>UIInterfaceOrientationPortrait</string>
            <string>UIInterfaceOrientationLandscapeLeft</string>
            <string>UIInterfaceOrientationLandscapeRight</string>
        </array>

        <key>UISupportedInterfaceOrientations~ipad</key>
        <array>
            <string>UIInterfaceOrientationPortrait</string>
            <string>UIInterfaceOrientationPortraitUpsideDown</string>
            <string>UIInterfaceOrientationLandscapeLeft</string>
            <string>UIInterfaceOrientationLandscapeRight</string>
        </array>

        <key>ITSAppUsesNonExemptEncryption</key>
        <false/>

        <!-- ─── Privacy Permissions ─────────────────────────────────────────── -->

        <!-- Photo Library: read (for file_picker + image_picker) -->
        <key>NSPhotoLibraryUsageDescription</key>
        <string>Invest Mkononi needs access to your photo library so you can upload your ID document or profile image.</string>

        <!-- Photo Library: write (saving captured images) -->
        <key>NSPhotoLibraryAddUsageDescription</key>
        <string>Invest Mkononi may save captured document images to your photo library.</string>

        <!-- Camera: required by image_picker for document capture -->
        <key>NSCameraUsageDescription</key>
        <string>Invest Mkononi needs camera access so you can photograph your ID document during account registration.</string>

        <!-- Microphone: required by iOS when camera is used (even for photo-only) -->
        <key>NSMicrophoneUsageDescription</key>
        <string>Invest Mkononi requires microphone access as part of iOS camera usage during document capture.</string>

    </dict>
</plist>